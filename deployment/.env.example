# Copy to .env and fill in. .env is gitignored (operator-local secrets).

# --- Default network if --network is omitted ---
# DEPLOY_NETWORK=testnet

# --- Broadcast controls ---
# DRY_RUN defaults to true: actions only plan, never broadcast.
# Set DRY_RUN=false for real chain broadcasts.
DRY_RUN=true
# BROADCAST is kept alongside DRY_RUN as an explicit operator flag.
BROADCAST=false

# --- Testnet ---
TESTNET_CKB_RPC_URL=https://testnet.ckb.dev/rpc
TESTNET_DEPLOYER_PRIVATE_KEY=0x

# --- Devnet (offckb) ---
DEVNET_CKB_RPC_URL=http://127.0.0.1:8114
DEVNET_DEPLOYER_PRIVATE_KEY=0x
# offckb devnet does not share public system-script outpoints. Populate these
# from your local chain (`offckb system-scripts`) so fee-paying secp cells resolve.
DEVNET_SECP256K1_BLAKE160_CODE_HASH=
DEVNET_SECP256K1_BLAKE160_HASH_TYPE=
DEVNET_SECP256K1_BLAKE160_DEP_TX_HASH=
DEVNET_SECP256K1_BLAKE160_DEP_INDEX=
DEVNET_SECP256K1_BLAKE160_DEP_TYPE=

# --- Mainnet (unused; testnet play-to-earn only) ---
MAINNET_CKB_RPC_URL=
MAINNET_DEPLOYER_PRIVATE_KEY=
