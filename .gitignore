# --- Rust / Cargo ---
# Build artifacts (the RISC-V contract binaries + host test builds live here).
target/
**/target/
*.rs.bk
# Coverage / profiling.
*.profraw
*.profdata
# NOTE: Cargo.lock IS committed — this workspace builds binaries (contracts),
# so we pin exact dependency versions for reproducible on-chain code hashes.

# --- Node / TypeScript (game-sdk, web app — when added) ---
node_modules/
**/node_modules/
dist/
build/
**/dist/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- CKB deployment / secrets ---
# Never commit keys, signed deployment payloads, or local migration state.
*.key
*.pem
*.secret
**/migrations/
deployment/.deployed/
# Generated deployment outputs are local operator state (outpoints/tx hashes).
deployment/artifacts/*
!deployment/artifacts/.gitkeep
.env
.env.*
!.env.example

# --- Editor / OS / tooling ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
*.log

# --- Claude Code local settings (machine-specific permissions) ---
.claude/
